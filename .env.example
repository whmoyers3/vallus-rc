# VRC — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Supabase project URL (from Settings → API in the Supabase dashboard)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service-role key (Settings → API → service_role key)
# This key bypasses Row Level Security — keep it server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase anon key (Settings → API → anon public key)
# This is safe to expose to the browser. It is only used for staff sign-in
# when VRC_AUTH_MODE=supabase.
SUPABASE_ANON_KEY=your-anon-key-here

# Auth mode: supabase, basic, or none.
# Keep basic for the current deployed app. Supabase staff login is deferred.
VRC_AUTH_MODE=basic

# Legacy shared password for HTTP Basic Auth.
# Only used when VRC_AUTH_MODE=basic.
APP_PASSWORD=choose-a-strong-password
